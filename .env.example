# Phavo local instance configuration
PHAVO_SECRET=change-me-in-production          # Server-side encryption key for credentials at rest
PHAVO_PORT=3000
PHAVO_HTTPS_PORT=3443
PHAVO_DATA_DIR=/data

# TLS mode: self-signed | acme | custom
PHAVO_TLS_MODE=self-signed
PHAVO_DOMAIN=                                  # Required for ACME mode

# Base64 DER SPKI or PEM Ed25519 public key used for offline license verification.
# Required in production when Celestial license activation is enabled.
PHAVO_LICENSE_PUBLIC_KEY=

# Current application version — shown in Settings → About and used for update checks
PHAVO_VERSION=0.1.0

# Local development only — injects a synthetic session for fast UI testing.
# The setup wizard still runs on first launch.
# Never set this to true in production.
PHAVO_DEV_MOCK_AUTH=false

# Development tier override — set to 'celestial' to test the full Celestial UI
# without activating a real license. Only respected when NODE_ENV=development.
# Has zero effect in production regardless of value.
# PHAVO_DEV_TIER=celestial

# ─── Gumroad Webhook (phavo.net deployment only) ─────────────────────────────
# Only needed on the server that receives Gumroad purchase webhooks.
# Self-hosted Phavo instances do not need any of these.
PHAVO_GUMROAD_WEBHOOK_SECRET=    # Gumroad webhook signing secret (from Gumroad dashboard)
PHAVO_LICENSE_PRIVATE_KEY=       # Ed25519 private key, base64-encoded PEM
PHAVO_GUMROAD_API_KEY=           # Gumroad API key (for writing license key to sale receipt)
