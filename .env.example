# ─── Core ───────────────────────────────────────────────────────────────────────────
# PHAVO_SECRET is optional — auto-generated and persisted to the data volume on first start.
# Set this explicitly if you want a fixed secret (e.g. for key migration or Kubernetes).
# PHAVO_SECRET=your-secret-here

PHAVO_PORT=3000
PHAVO_HTTPS_PORT=3443
PHAVO_DATA_DIR=/data

# TLS mode: self-signed | acme | custom
PHAVO_TLS_MODE=self-signed
PHAVO_DOMAIN=                                  # Required for ACME mode
