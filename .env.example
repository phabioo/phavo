# Phavo local instance configuration
PHAVO_SECRET=change-me-in-production          # Server-side encryption key for credentials at rest
PHAVO_PORT=3000
PHAVO_HTTPS_PORT=3443
PHAVO_DATA_DIR=/data

# TLS mode: self-signed | acme | custom
PHAVO_TLS_MODE=self-signed
PHAVO_DOMAIN=                                  # Required for ACME mode

# phavo.net licence validation (leave empty for fully offline Local tier)
PHAVO_IO_URL=https://phavo.net

# Current application version — shown in Settings → About and used for update checks
PHAVO_VERSION=0.1.0

# Local development only — bypasses phavo.net validation and injects a synthetic
# free-tier session. The setup wizard still runs on first launch.
# Never set this to true in production.
PHAVO_DEV_MOCK_AUTH=false

# Development tier override — set to 'celestial' to test the full Celestial UI
# without activating a real license. Only respected when NODE_ENV=development.
# Has zero effect in production regardless of value.
# PHAVO_DEV_TIER=celestial
