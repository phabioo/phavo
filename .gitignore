# ─── Node / Bun ──────────────────────────────────────────────────────────────
node_modules/
.cache/

# ─── SvelteKit ───────────────────────────────────────────────────────────────
.svelte-kit/
build/

# ─── Turborepo ───────────────────────────────────────────────────────────────
.turbo/

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Dev runtime data ────────────────────────────────────────────────────────
# Local dev data directories (server creates these at ${PHAVO_DATA_DIR})
.dev-data/
.phavo-data/

# Nested dev-data artifact: happens when PHAVO_DATA_DIR=./apps/web/.dev-data
# is resolved relative to --cwd apps/web instead of the repo root
apps/web/apps/

# Container / production data dir (never committed)
/data/
# App runtime data directory (created by server at PHAVO_DATA_DIR)
apps/web/data/

# ─── Database ────────────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm

# ─── Secrets / environment ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
secret.key
*.pem
*.key

# ─── Build outputs ───────────────────────────────────────────────────────────
dist/
apps/web/.svelte-kit/

# ─── Test outputs ────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-error.log*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Editor ──────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
# Ignore all VS Code user-specific files; keep shared extension recommendations
.vscode/*
!.vscode/extensions.json
!.vscode/mcp.json

# ─── Old AI context docs ─────────────────────────────────────────────────────
CLAUDE_v*.txt
CLAUDE_v*.md

# ─── AI tooling ──────────────────────────────────────────────────────────────
.claude/
.superpowers/
.playwright-mcp/

# ─── Generated / ephemeral docs ──────────────────────────────────────────────
docs/ui-audit-report.md
docs/screenshots/
docs/superpowers/
