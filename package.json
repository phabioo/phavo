{
  "name": "phavo",
  "version": "0.8.9",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./node_modules/turbo/bin/turbo run dev",
    "build": "node ./node_modules/turbo/bin/turbo run build",
    "lint": "node ./node_modules/@biomejs/biome/bin/biome check .",
    "format": "node ./node_modules/@biomejs/biome/bin/biome format --write .",
    "typecheck": "node ./node_modules/turbo/bin/turbo run typecheck",
    "clean": "node ./node_modules/turbo/bin/turbo run clean",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@tailwindcss/vite": "^4.2.2",
    "turbo": "latest",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "drizzle-orm": "0.45.1"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.1.0"
  }
}
